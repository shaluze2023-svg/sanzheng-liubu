# 三省六部制 — 环境变量配置模板
# 复制此文件为 .env 并填入实际 API Keys

# ============================================================
# 通用配置
# ============================================================
# 调试模式
DEBUG_SANZHENG="false"

# OpenCode 配置路径
OPENCODE_CONFIG_DIR=""

# ============================================================
# Anthropic API（Claude 系列）
# ============================================================
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# 中书省（主 API）
ZHONGSHU_API_KEY="your-anthropic-api-key"
ZHONGSHU_MODEL="anthropic/claude-4-6-opus"
ZHONGSHU_BASE_URL="https://api.anthropic.com"

# 门下省（次 API）
MENXIA_API_KEY="your-anthropic-api-key"
MENXIA_MODEL="anthropic/claude-4-6-opus"
MENXIA_BASE_URL="https://api.anthropic.com"

# 尚书省（执行 API）
SHANGSHU_API_KEY="your-anthropic-api-key"
SHANGSHU_MODEL="anthropic/claude-4-6-opus"
SHANGSHU_BASE_URL="https://api.anthropic.com"

# ============================================================
# OpenAI API（GPT 系列）
# ============================================================
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"

# 若使用 OpenAI 兼容的第三方服务（如 DeepSeek、Azure OpenAI 等），修改 BASE_URL 即可
# OPENAI_BASE_URL="https://api.deepseek.com/v1"

# ============================================================
# Google Gemini API
# ============================================================
GOOGLE_API_KEY="your-google-api-key"
GOOGLE_BASE_URL="https://generativelanguage.googleapis.com"

# ============================================================
# 六部 API Keys
# 可按需选择不同提供商，格式为 provider/model-name
# ============================================================

# 吏部 — 项目管理与版本控制
LI_BU_API_KEY="your-anthropic-api-key"
LI_BU_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: LI_BU_MODEL="openai/gpt-4o"
# 或使用 Gemini: LI_BU_MODEL="google/gemini-2.5-pro"

# 户部 — 事务数据处理与成本核算
HU_BU_API_KEY="your-anthropic-api-key"
HU_BU_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: HU_BU_MODEL="openai/gpt-4o"
# 或使用 Gemini: HU_BU_MODEL="google/gemini-2.5-pro"

# 礼部 — 代码规范与文档生成
LI_BU_LI_API_KEY="your-anthropic-api-key"
LI_BU_LI_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: LI_BU_LI_MODEL="openai/gpt-4o"
# 或使用 Gemini: LI_BU_LI_MODEL="google/gemini-2.5-pro"

# 兵部 — 安全分析与测试部署
BING_BU_API_KEY="your-anthropic-api-key"
BING_BU_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: BING_BU_MODEL="openai/gpt-4o"
# 或使用 Gemini: BING_BU_MODEL="google/gemini-2.5-pro"

# 刑部 — 合规审计与故障调试
XING_BU_API_KEY="your-anthropic-api-key"
XING_BU_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: XING_BU_MODEL="openai/gpt-4o"
# 或使用 Gemini: XING_BU_MODEL="google/gemini-2.5-pro"

# 工部 — 代码编写与功能构建
GONG_BU_API_KEY="your-anthropic-api-key"
GONG_BU_MODEL="anthropic/claude-4-6-opus"
# 或使用 OpenAI: GONG_BU_MODEL="openai/gpt-4o"
# 或使用 Gemini: GONG_BU_MODEL="google/gemini-2.5-pro"